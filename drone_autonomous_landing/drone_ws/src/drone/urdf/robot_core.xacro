<?xml version="1.0"?>
<robot name="simple_quadrotor" xmlns:xacro="http://ros.org/wiki/xacro">
  <!-- Base -->
  <link name="base_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.02"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.12"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.12"/>
      </geometry>
    </collision>
  </link>

  <!-- 4 Arms -->
  <xacro:macro name="arm" params="name xyz rpy">
    <link name="${name}">
      <inertial>
        <mass value="0.1"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0002"/>
      </inertial>
      <visual>
        <geometry>
          <cylinder length="0.25" radius="0.01"/>
        </geometry>
        <material name="black">
          <color rgba="0 0 0 1"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder length="0.25" radius="0.01"/>
        </geometry>
      </collision>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>
  </xacro:macro>

  <xacro:arm name="arm_1" xyz="0.18 0 0" rpy="0 0 0"/>
  <xacro:arm name="arm_2" xyz="-0.18 0 0" rpy="0 0 0"/>
  <xacro:arm name="arm_3" xyz="0 0.18 0" rpy="0 0 1.5708"/>
  <xacro:arm name="arm_4" xyz="0 -0.18 0" rpy="0 0 1.5708"/>

  <!-- 4 Propellers -->
  <xacro:macro name="propeller" params="name xyz">
    <link name="${name}">
      <inertial>
        <mass value="0.01"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00002"/>
      </inertial>
      <visual>
        <geometry>
          <cylinder length="0.01" radius="0.04"/>
        </geometry>
        <material name="red">
          <color rgba="1 0 0 1"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder length="0.01" radius="0.04"/>
        </geometry>
      </collision>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${xyz}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:propeller name="propeller_1" xyz="0.18 0 0.03"/>
  <xacro:propeller name="propeller_2" xyz="-0.18 0 0.03"/>
  <xacro:propeller name="propeller_3" xyz="0 0.18 0.03"/>
  <xacro:propeller name="propeller_4" xyz="0 -0.18 0.03"/>

</robot>
